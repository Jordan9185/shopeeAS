// shopee-line-bot — Prisma schema
// 設計文件：docs/superpowers/specs/2026-07-20-shopee-line-bot-design.md

generator client {
  provider      = "prisma-client-js"
  // rhel-openssl-3.0.x 是 Vercel serverless 執行環境需要的 binary target
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 已觀測過的商品。
///
/// 刻意不綁定特定電商平台：主鍵是 (platform, externalId)，
/// 而非蝦皮專屬的 (shopId, itemId)。不同平台的商品 ID 可能撞號，
/// 若不帶 platform，momo 的商品會蓋掉蝦皮同號的商品。
///
/// 價格一律以「分」為單位的整數儲存（NT$299 → 29900），避免浮點誤差。
model Product {
  /// 平台代號，例如 "shopee"、"momo"
  platform String
  /// 該平台內可唯一識別商品的字串。
  /// 蝦皮為 "{shopId}.{itemId}"；其他平台格式由各自的 provider 決定
  externalId String

  title    String
  imageUrl String
  /// 商品原始網址（未加分潤參數），用於重新產生連結
  productUrl String

  currentPrice  Int
  originalPrice Int?
  /// 本系統觀測到的最低價
  lowestPrice Int

  /// 首次收錄時間。首次觀測時最低價必然等於現價，不可宣稱為歷史最低
  firstSeenAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@id([platform, externalId])
}

/// 使用者追蹤的商品。
///
/// 刻意不做主動推播：LINE 的推播訊息有每月則數上限且超額要付費，
/// 而回覆訊息免費且無上限。使用者主動詢問「我的追蹤」時才回覆清單，
/// 成本為零。日後若要加推播，這張表就是名單來源。
model Tracking {
  /// LINE 的使用者 ID。同一人在不同群組追蹤的商品會合併在一起
  lineUserId String
  platform   String
  externalId String

  /// 加入追蹤當下的價格，用於顯示「追蹤後的變化」
  priceAtTrack Int
  createdAt    DateTime @default(now())

  @@id([lineUserId, platform, externalId])
  /// 日後推播時需要反查「有哪些人在追蹤這個商品」
  @@index([platform, externalId])
}
