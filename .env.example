# ============================================
# 範本檔 — 這份會進 git，所以一律留空值
# 複製成 .env 後再填入真實金鑰
#   cp .env.example .env
# ============================================

# --------------------------------------------
# 資料庫 — Neon PostgreSQL
# --------------------------------------------
# 必須用 pooled connection string（網址含 -pooler）
# serverless 每次冷啟動都開新連線，直連會很快耗盡連線數
DATABASE_URL=""

# --------------------------------------------
# LINE Messaging API
# --------------------------------------------
# LINE Developers Console → Channel → Basic settings
LINE_CHANNEL_SECRET=""

# LINE Developers Console → Channel → Messaging API 分頁最下方
# 點 Issue 生成 long-lived token
LINE_CHANNEL_ACCESS_TOKEN=""

# --------------------------------------------
# 蝦皮聯盟 API
# --------------------------------------------
# mock      = 假資料，不需憑證，用於審核通過前的開發
# affiliate = 真實呼叫蝦皮聯盟 GraphQL API
SHOPEE_PROVIDER="mock"

# 聯盟審核通過後才會拿到，SHOPEE_PROVIDER=mock 時可留空
SHOPEE_APP_ID=""
SHOPEE_APP_SECRET=""

# 機器人自身的 userId，用於判定 @ 標註是否指向本機器人
# 取得方式：GET https://api.line.me/v2/bot/info
LINE_BOT_USER_ID=""

# 蝦皮聯盟 GraphQL 端點。留空使用預設值
# 預設：https://open-api.affiliate.shopee.tw/graphql
SHOPEE_AFFILIATE_ENDPOINT=""
